# ============================================
# Finance Exam System Backend - Environment
# ============================================

# --- JWT ---
JWT_SECRET=replace-me-with-random-32-bytes
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# --- Passwords (单密码登录) ---
USER_PASSWORD=replace-me
ADMIN_PASSWORD=replace-me-admin

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///../../data/final/finance.db
APP_DB_URL=sqlite+aiosqlite:///./data/app.db

# --- Grading ---
MIN_COVERAGE=0.6

# --- App ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
APP_NAME=Finance Exam System
DEBUG=false

# --- LLM (DeepSeek, OpenAI-compatible) — 仅 AI 讲解模块 ---
# 未配置时 explain 端点 graceful fallback 到 stub（不报错）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat