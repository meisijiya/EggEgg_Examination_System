# ===============================================
# Finance Exam System — Production Environment
# ===============================================
#
# ⚠️  使用流程:
#   1. cp .env.example .env
#   2. 编辑下方必填项 (JWT_SECRET / USER_PASSWORD / ADMIN_PASSWORD / CORS_ORIGINS)
#   3. 生成 JWT_SECRET:  python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 📝 本文件入 git; .env 不入 git. 部署前必须填真实值.
#
# 🇨🇳 中文注释 — 关键决策点 (为什么这样配) 标注 # 决策: 说明

# -----------------------------------------------
# 🔐 必填: JWT 密钥
# -----------------------------------------------
# 决策: token_urlsafe(32) → 43 字符 base64url, 256 bit 熵, JWT HS256 足够安全
# 生产前必须替换, 否则攻击者可伪造 token
JWT_SECRET=replace-me-with-token-urlsafe-32

# -----------------------------------------------
# 🔐 必填: 单密码登录 (USER / ADMIN 区分角色)
# -----------------------------------------------
# 决策: USER_PASSWORD 给普通考生, ADMIN_PASSWORD 给管理员
# 生产前必须改; 不要用生日 / 名字等弱密码
# 长度建议 ≥ 12 位, 含大小写 + 数字 + 符号
USER_PASSWORD=change-me-user-password
ADMIN_PASSWORD=change-me-admin-password

# -----------------------------------------------
# 数据库 — 容器内路径 (与 docker-compose volume 挂载配合)
# -----------------------------------------------
# 决策: /app/data/final/finance.db 通过 ./data:/app/data volume 挂载
# 注意: aiosqlite 路径前缀 3 个斜杠 (///) 表示相对或绝对路径
DATABASE_URL=sqlite+aiosqlite:////app/data/final/finance.db
APP_DB_URL=sqlite+aiosqlite:////app/data/app.db

# -----------------------------------------------
# 判分阈值 — 简答题关键词覆盖率下限
# -----------------------------------------------
# 决策: 0.6 = 必须命中 60% 关键词才给满分 (避免宽松给分)
# 调高更严苛; 调低更宽松
MIN_COVERAGE=0.6

# -----------------------------------------------
# CORS — 允许的前端来源
# -----------------------------------------------
# 决策: 生产环境只允许自家域名 + 本地开发端口
# 多域名逗号分隔, 不要带通配符 * (FastAPI credentials=true 不允许)
CORS_ORIGINS=https://your-domain.com,http://localhost:5173

# -----------------------------------------------
# 应用元信息
# -----------------------------------------------
APP_NAME=Finance Exam System
DEBUG=false  # 决策: 生产环境必须 false, 避免泄露堆栈

# -----------------------------------------------
# AI 讲解 (DeepSeek) — 当前为占位, 后续接入
# -----------------------------------------------
# 决策: 当前 main.py 的 /exams/{id}/explain 是 stub, 不调用 DeepSeek
# 接入时填 API Key 即可, 配置层已预留 (见 config.py)
# 不填时不影响其他功能运行
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# -----------------------------------------------
# JWT 算法与有效期
# -----------------------------------------------
# 决策: HS256 单密钥对称, MVP 阶段够用; 后期用户量大可换 RS256
# 43200 分钟 = 30 天 (考试场景: 一次性考试不需要频繁重新登录)
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200